# Copy this file to .env.test and fill in values for the *staging* Supabase
# project. NEVER point these at production — tests do destructive CRUD via the
# service role key, scoped to E2E_TEST_SALON_ID.

# --- Staging Supabase project ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-STAGING-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# --- Test salon (one row in staging.salons; all test data is scoped to it) ---
E2E_TEST_SALON_ID=00000000-0000-0000-0000-000000000000

# --- Test users (created in staging Auth + linked to E2E_TEST_SALON_ID) ---
E2E_ADMIN_EMAIL=e2e-admin@lume-test.local
E2E_ADMIN_PASSWORD=

E2E_OWNER_EMAIL=e2e-owner@lume-test.local
E2E_OWNER_PASSWORD=

E2E_OPERATOR_EMAIL=e2e-operator@lume-test.local
E2E_OPERATOR_PASSWORD=

E2E_CLIENT_EMAIL=e2e-client@lume-test.local
E2E_CLIENT_PASSWORD=

# --- Optional ---
# E2E_BASE_URL=http://localhost:3000
